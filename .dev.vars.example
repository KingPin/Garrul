# Copy this file to .dev.vars for local `wrangler dev`.
# .dev.vars is gitignored. NEVER commit real secrets.

# Always required (placeholders OK for local dev where the feature is unused).
JWT_SECRET="dev-jwt-secret-change-me"
IP_HASH_SECRET="dev-ip-hash-pepper-change-me"

# Turnstile (use Cloudflare's "always passes" testing keys for local dev).
# https://developers.cloudflare.com/turnstile/troubleshooting/testing/
TURNSTILE_SITE_KEY="1x00000000000000000000AA"
TURNSTILE_SECRET="1x0000000000000000000000000000000AA"

# OAuth — leave blank locally unless testing the OAuth flow.
GH_CLIENT_ID=""
GH_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email — Resend default. Leave blank to disable notification sends locally.
RESEND_API_KEY=""

# Legacy single-URL webhook (only honored while no endpoints are
# configured on /admin/webhooks — prefer endpoint rows: signed + retried).
WEBHOOK_URL=""

# Optional: Cloudflare API token (Analytics read) for the /admin/usage
# page. Pair with CF_ACCOUNT_ID in wrangler.toml [vars].
CF_API_TOKEN=""

# Optional: GitHub token for the "update available" check on /admin/*.
# Unauthenticated GitHub API allows 60 req/hr per IP; Cloudflare egress IPs
# are shared across colos so a token raises the cap. Read-only `public_repo`
# scope is sufficient. Set via `wrangler secret put GITHUB_TOKEN` in prod.
GITHUB_TOKEN=""
