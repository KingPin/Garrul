{
  "name": "garrul",
  "version": "1.13.1",
  "private": true,
  "description": "Self-hosted comment system on Cloudflare Workers + D1 + KV",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/KingPin/Garrul"
  },
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "wrangler dev",
    "predev": "npm run build:assets",
    "deploy": "wrangler deploy",
    "predeploy": "npm run build:assets",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "prebuild": "npm run build:assets",
    "build:embed": "tsx scripts/build-embed.ts",
    "build:agents": "tsx scripts/build-agents-md.ts",
    "build:assets": "npm run build:embed && npm run build:agents && npm run build:version",
    "size": "npm run build:embed && tsx scripts/check-bundle-size.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.widget.json",
    "pretypecheck": "npm run build:assets",
    "lint": "echo 'lint placeholder — wire up biome or eslint later' && exit 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "tsx src/db/migrate.ts",
    "rerender": "tsx scripts/rerender.ts",
    "seed-demo": "tsx scripts/seed-demo.ts",
    "import-disqus": "tsx scripts/import-disqus.ts",
    "db:export": "bash scripts/db-export.sh",
    "upgrade": "tsx scripts/upgrade.ts",
    "manifest:build": "tsx scripts/upgrade/build-manifest.ts",
    "manifest:check": "tsx scripts/upgrade/build-manifest.ts --check",
    "build:version": "tsx scripts/build-version.ts",
    "tail": "wrangler tail"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "marked": "^18.0.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.6",
    "@cloudflare/workers-types": "^4.20251101.0",
    "@types/node": "^25.8.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.6",
    "wrangler": "^4.0.0"
  }
}
